{
    "name": "wireninja/prasmanan",
    "description": "The opinionated Filament Super Booster kit by WireNinja.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "WireNinja",
            "email": "yohanesekaadhisetiawan@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "bezhansalleh/filament-shield": "^4.0",
        "brick/math": "^0.14.1",
        "filament/filament": "^5.0",
        "filament/spatie-laravel-media-library-plugin": "^5.0",
        "laragear/webauthn": "^4.0",
        "laravel-notification-channels/webpush": "^10.4",
        "laravel/framework": "^12.0",
        "laravel/socialite": "^5.24",
        "livewire/livewire": "^4.0",
        "livewire/volt": "^1.10",
        "spatie/laravel-activitylog": "^4.10",
        "laravel/nightwatch": "^1.24",
        "maatwebsite/excel": "^3.1",
        "laravel-lang/common": "^6.7",
        "spatie/laravel-pdf": "^2.2",
        "dompdf/dompdf": "^3.1",
        "gotenberg/gotenberg-php": "^2.17",
        "spatie/laravel-backup": "^10.0",
        "spatie/laravel-settings": "^3.0",
        "spatie/laravel-data": "^4.0",
        "laravel-notification-channels/telegram": "^6.0",
        "laravel/horizon": "^5.45",
        "chillerlan/php-qrcode": "^5.0",
        "laravel/scout": "^11.0",
        "meilisearch/meilisearch-php": "^1.16",
        "http-interop/http-factory-guzzle": "^1.2",
        "laravel/reverb": "^1.8"
    },
    "require-dev": {
        "rector/rector": "^2.3",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.24",
        "driftingly/rector-laravel": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "WireNinja\\Prasmanan\\": "src/"
        },
        "files": [
            "src/Helpers/type_cast.php",
            "src/Helpers/auth.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "WireNinja\\Prasmanan\\PrasmananServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
